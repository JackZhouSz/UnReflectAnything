#!/bin/bash

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$1" in
    -h|--help)
        echo "Usage: unreflect {train|test|sweep|agent|completion} [args]"
        echo ""
        echo "Subcommands:"
        echo "  train       Run training (train.py)"
        echo "  test        Run tests (test.py)"
        echo "  sweep       Launch a Weights & Biases sweep (config_sweep.yaml)"
        echo "  agent       Run a W&B sweep agent"
        echo "  completion  Print shell completion script (bash|zsh)"
        echo ""
        echo "Options:"
        echo "  -h, --help   Show this help and exit"
        echo ""
        echo "Tab completion: source <(unreflect completion)   # then unreflect <TAB>"
        exit 0
        ;;
    completion)
        shift
        sh="${1:-${SHELL}}"
        if [[ "$sh" == *bash* ]]; then
            cat "$SCRIPT_DIR/unreflect-completion.bash"
        elif [[ "$sh" == *zsh* ]]; then
            cat "$SCRIPT_DIR/unreflect-completion.zsh"
        else
            cat "$SCRIPT_DIR/unreflect-completion.bash"
        fi
        exit 0
        ;;
    train)
        shift
        python "$SCRIPT_DIR/../train.py" "$@"
        ;;
    test)
        shift
        python "$SCRIPT_DIR/../test.py" "$@"
        ;;
    sweep)
        shift
        wandb sweep "$SCRIPT_DIR/../config_sweep.yaml"
        ;;
    agent)
        shift
        wandb agent "$@"
        ;;
    *)
        echo "Usage: unreflect {train|test|sweep|agent|completion} [args]"
        echo "Try 'unreflect --help' for more information."
        exit 1
        ;;
esac